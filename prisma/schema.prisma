generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionKind {
  income
  expense
}

enum TransactionCategory {
  salario
  freelance
  investimentos
  vendas
  reembolso
  bonus
  outros_receitas
  alimentacao
  moradia
  transporte
  saude
  educacao
  lazer
  impostos
  assinaturas
  contas
  compras
  outros_gastos
}

model Transaction {
  id          Int                 @id @default(autoincrement())
  kind        TransactionKind
  amount      Decimal             @db.Decimal(12, 2)
  category    TransactionCategory
  description String              @default("")
  occurredOn  DateTime            @map("occurred_on") @db.Date
  createdAt   DateTime            @default(now()) @map("created_at")
  userPhone   String              @map("user_phone")
  user        User                @relation(fields: [userPhone], references: [phone], onDelete: Restrict)

  @@index([kind, occurredOn], map: "idx_transactions_kind_occurred_on")
  @@index([occurredOn], map: "idx_transactions_occurred_on")
  @@index([userPhone], map: "idx_transactions_user_phone")
  @@map("transactions")
}

model User {
  id           Int           @id @default(autoincrement())
  phone        String        @unique
  createdAt    DateTime      @default(now()) @map("created_at")
  transactions Transaction[]

  @@map("users")
}
